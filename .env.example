# Copy to .env.local and fill in. Vite only exposes VITE_* vars to the client.

# --- LLM transport --------------------------------------------------------
# Preferred: a Cloudflare Worker proxy that holds the Featherless key
# server-side. See workers/llm-proxy. Set this to the deployed worker URL
# and leave VITE_FEATHERLESS_API_KEY empty.
VITE_LLM_PROXY_URL=

# Direct (only for local dev / private demos — key ends up in the bundle).
VITE_FEATHERLESS_API_KEY=

# Optional model override (default: google/gemma-2-9b-it).
# VITE_FEATHERLESS_MODEL=google/gemma-2-9b-it

# --- Google Maps APIs (Geocoding, Places, Embed) --------------------------
# When unset the app falls back to OpenStreetMap.
# https://developers.google.com/maps/documentation/javascript/get-api-key
VITE_GOOGLE_MAPS_API_KEY=

# --- Google Analytics 4 ---------------------------------------------------
# Format: G-XXXXXXXXXX. When unset, analytics calls are no-ops.
VITE_GA_MEASUREMENT_ID=
