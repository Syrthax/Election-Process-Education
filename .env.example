# Copy to .env.local and fill in. Vite only exposes VITE_* vars to the client.

# --- Featherless AI (LLM assistant) ---------------------------------------
# Get a key from https://featherless.ai
VITE_FEATHERLESS_API_KEY=
# Optional model override (default: google/gemma-2-9b-it).
# VITE_FEATHERLESS_MODEL=google/gemma-2-9b-it

# --- Google Maps Embed API (polling-booth map) ----------------------------
# When unset the app falls back to OpenStreetMap (no key needed).
# Get a key: https://developers.google.com/maps/documentation/embed/get-api-key
VITE_GOOGLE_MAPS_API_KEY=

# --- Google Analytics 4 ---------------------------------------------------
# Format: G-XXXXXXXXXX. When unset, analytics calls are no-ops.
# Set up a property: https://analytics.google.com
VITE_GA_MEASUREMENT_ID=
