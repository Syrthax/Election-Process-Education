# Copy this file to .env.local and fill in your keys.
# Vite only exposes variables prefixed with VITE_ to the client.

# Featherless AI — used by the QueryGuard chat assistant.
# Get a key from https://featherless.ai
VITE_FEATHERLESS_API_KEY=

# Optional: override the default Featherless model (default: google/gemma-2-9b-it).
# VITE_FEATHERLESS_MODEL=google/gemma-2-9b-it
